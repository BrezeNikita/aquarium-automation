  <property name="styleSheet">
   <string notr="true">
/* Общий фон — тёплый белый */
QMainWindow, QWidget#centralwidget {
    background-color: #f5f7fa;
}

/* Все вложенные виджеты наследуют фон */
QWidget {
    background-color: transparent;
}

/* Карточки-группы */
QGroupBox {
    background-color: #ffffff;
    border: 1px solid #dde3ea;
    border-radius: 12px;
    margin-top: 10px;
    padding: 8px 10px 10px 10px;
    font-family: 'Segoe UI', sans-serif;
    font-size: 9pt;
    font-weight: bold;
    color: #8896a5;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 14px;
    padding: 0 4px;
    background-color: #ffffff;
    color: #8896a5;
    font-size: 8pt;
    letter-spacing: 1px;
    text-transform: uppercase;
}

/* Метки */
QLabel {
    color: #2c3e50;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
    background-color: transparent;
}
QLabel#appTitleLabel {
    font-size: 14pt;
    font-weight: bold;
    color: #2c3e50;
}

/* Кнопки по умолчанию */
QPushButton {
    background-color: #eef1f5;
    color: #2c3e50;
    border: 1px solid #d0d7e0;
    border-radius: 8px;
    padding: 7px 14px;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
}
QPushButton:hover {
    background-color: #e0e7f0;
    border-color: #b0bec5;
}
QPushButton:pressed {
    background-color: #cfd8e3;
}

/* Старт — зелёный, спокойный */
QPushButton#startButton {
    background-color: #e8f5e9;
    color: #2e7d32;
    border: 1px solid #a5d6a7;
    border-radius: 8px;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
    font-weight: bold;
}
QPushButton#startButton:hover {
    background-color: #c8e6c9;
    border-color: #81c784;
}
QPushButton#startButton:pressed { background-color: #a5d6a7; }

/* Пауза — жёлтый */
QPushButton#pauseButton {
    background-color: #fff8e1;
    color: #f57f17;
    border: 1px solid #ffe082;
    border-radius: 8px;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
    font-weight: bold;
}
QPushButton#pauseButton:hover { background-color: #ffecb3; }
QPushButton#pauseButton:pressed { background-color: #ffe082; }

/* Сброс — нейтральный */
QPushButton#resetButton {
    background-color: #eceff1;
    color: #546e7a;
    border: 1px solid #cfd8dc;
    border-radius: 8px;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
}
QPushButton#resetButton:hover { background-color: #cfd8dc; }

/* Кнопка аварии */
QPushButton#clogButton {
    background-color: #fce4ec;
    color: #c62828;
    border: 1px solid #ef9a9a;
    border-radius: 8px;
    font-family: 'Segoe UI', sans-serif;
    font-size: 10pt;
}
QPushButton#clogButton:hover { background-color: #ffcdd2; }
QPushButton#clogButton:pressed { background-color: #ef9a9a; }

/* Журнал */
QTextEdit#logTextEdit {
    background-color: #f9fafb;
    color: #4a5568;
    border: 1px solid #dde3ea;
    border-radius: 8px;
    font-family: 'Consolas', 'Courier New', monospace;
    font-size: 9pt;
    padding: 6px;
}

/* Аквариум */
QGraphicsView#graphicsView {
    border: 2px solid #b0c4d8;
    border-radius: 12px;
    background-color: #e8f4fd;
}
